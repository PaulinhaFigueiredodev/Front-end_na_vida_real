doctype html 
html(lang="pt-BR")
    head
    //- Metas - Serve para controlar o responsivo
    //- ============================================
    meta(name="viewport" contents="width=device-width, minimum-scale=1.0, maximum-scale=1.0")
    meta(charset="utf-8")

    - var title = "Projeto Front-End Title"
    - var description = "Projeto Front-End Description"

    //- SEO
     Descricao que o google le para saber o que é a pagina
    meta(name="robots" content="Projeto Front-End Description")
    //- Facilita para o google que a pagina precisa ser indexada
    meta(name="robots" content="index,follow")
    title=title

    //- Open Graph
    meta(property="og:type" content="website")
    meta(property="og:title" content=title)
    meta(property="og:description" content=description)
    meta(property="og:url" content="https://github.com/PaulinhaFigueiredodev/Front-end_na_vida_real/tree/main/csshortcut-app")
    meta(property="og:image" content="https://ia.media-imdb.com/images/rock.jpg")

    //- Twitter Cards
    meta(name="twitter:card" content="summary_large_image")
    meta(name="twitter:title" content=title)
    meta(name="twitter:description" content=description)
    meta(name="twitter:url" content="https://github.com/PaulinhaFigueiredodev/Front-end_na_vida_real/tree/main/csshortcut-app")
    meta(name="twitter:image" content="https://ia.media-imdb.com/images/rock.jpg")

    //- Styles
    //- ==========================================================================
    link(rel="stylesheet" href="assets/styles/style.css")

    body 
        header header
        main main
        footer footer

        scrip(type="text/javasrcipt"  src="assets/scripts/script.js" async)
